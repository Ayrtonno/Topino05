{
  "name": "preventivatore-magazzino",
  "version": "1.0.0",
  "description": "Electron app per gestire preventivi e magazzino",
  "main": "dist-ts/main.js",
  "homepage": "./",
  "author": "Topino",
  "license": "MIT",
  "scripts": {
    "start": "npm run build:ts && electron .",
    "start:dev": "electron .",
    "rebuild": "npm run build:ts",
    "build:ts": "node tools/build-ts.js",
    "build:dir": "npm run build:ts && electron-builder --dir",
    "build": "npm run build:ts && electron-builder --win",
    "test": "echo \"No tests configured\""
  },
  "dependencies": {
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ajv": "^8.18.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "esbuild": "^0.24.2",
    "typescript": "^4.9.5"
  },
  "build": {
    "appId": "com.topino.preventivatore",
    "productName": "Preventivatore Magazzino",
    "files": [
      "dist-ts/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "./releases"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
